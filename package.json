{
  "name": "school-ops-agent-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:api": "nodemon --exec \"node --env-file-if-exists=.env\" --watch src --ignore work --ignore dist src/server.js",
    "api": "node --env-file-if-exists=.env src/server.js",
    "start": "node --env-file-if-exists=.env src/server.js",
    "build": "vite build",
    "preview": "node --env-file-if-exists=.env src/server.js",
    "test": "node --test"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "cron": "^2.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.0.0",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.4.21",
    "multer": "^2.0.2",
    "pdf-parse": "^2.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tesseract.js": "^4.1.1",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "nodemon": "^3.1.14"
  }
}
